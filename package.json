{
  "name": "soul-agent",
  "version": "0.1.0",
  "description": "Metacognitive Telegram Bot with soul system, self-evolution, and multi-agent architecture",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node --import tsx/esm restart.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "node --import tsx/esm scripts/init-soul.ts",
    "postinstall": "node scripts/install-all.js",
    "doctor": "node --import tsx/esm scripts/doctor.ts",
    "db:import": "node --import tsx/esm src/core/db-import.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@andresaya/edge-tts": "^1.8.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.6.2",
    "docxtemplater": "^3.68.2",
    "dotenv": "^16.4.0",
    "esbuild": "^0.27.3",
    "exceljs": "^4.4.0",
    "grammy": "^1.35.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pizzip": "^3.2.0",
    "zod": "^3.24.0"
  },
  "overrides": {
    "minimatch": ">=10.2.1",
    "hono": ">=4.12.4",
    "@hono/node-server": ">=1.19.10",
    "rollup": ">=4.59.0",
    "express-rate-limit": ">=8.2.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260218.1",
    "cclsp": "^0.7.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.1.3",
    "vitest": "^3.0.0"
  }
}

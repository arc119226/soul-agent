# ─── 核心設定 ───

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Allowed Telegram user IDs (comma-separated, leave empty to allow everyone)
ALLOWED_USERS=

# Admin user ID (receives approval requests, has full access)
ADMIN_USER_ID=

# Bot persona (system prompt personality)
BOT_PERSONA=

# ─── Claude Code 整合 ───

# Default working directory for Claude Code
CLAUDE_CODE_CWD=

# Claude Code timeout in milliseconds (default: 300000 = 5min)
CLAUDE_CODE_TIMEOUT=300000

# Claude Code model override (empty = CLI default)
CLAUDE_CODE_MODEL=

# Max turns for Claude Code (default: 0 = unlimited)
CLAUDE_CODE_MAX_TURNS=0

# Enable experimental Agent Teams (multi-agent collaboration)
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# ─── Claude API（直接 SDK 呼叫） ───

# Anthropic API Key (optional — only for route-decision LLM classifier)
# Main CLI path uses its own auth (claude login). Leave empty if CLI-only.
ANTHROPIC_API_KEY=

# ─── 模型路由層級 ───

# Haiku tier: greetings, confirmations, casual chat (fast, cheap)
MODEL_TIER_HAIKU=claude-haiku-4-5-20251001

# Sonnet tier: general discussion, Q&A, daily conversation
MODEL_TIER_SONNET=claude-sonnet-4-6

# Opus tier: code, technical analysis, complex research (empty = CLI default)
MODEL_TIER_OPUS=

# ─── 工具審批 ───

# Port for approval IPC server (default: 3691)
APPROVAL_PORT=3691

# Approval timeout in milliseconds (default: 120000 = 2min)
APPROVAL_TIMEOUT=120000

# ─── 速率限制 ───

# Max Claude requests per user per day (0 = unlimited)
DAILY_REQUEST_LIMIT=0

# ─── 記憶 ───

# Max context messages per chat
MAX_CONTEXT_MESSAGES=30

# Max user facts per user
USER_FACT_LIMIT=20

# ─── 進化系統 ───

# External knowledge URLs (comma-separated)
KNOWLEDGE_URLS=

# Max auto-evolves per day (default: 3)
MAX_AUTO_EVOLVES_PER_DAY=3

# Auto-restart after core evolution (default: false)
AUTO_RESTART_AFTER_EVOLVE=false

# Trust mode for evolution (default: false)
EVOLVE_TRUST_MODE=false

# Auto push after successful evolution (default: false)
AUTO_PUSH_ENABLED=false

# When to require approval before push: never/high/medium/all (default: high)
AUTO_PUSH_REQUIRE_APPROVAL=high

# EVOLUTION_PRE_CHECK_STRICT=false  # Set true to block evolution on pre-check mismatch

# ─── 生活週期 ───

# Timezone (default: Asia/Taipei)
TIMEZONE=Asia/Taipei

# Quiet hours start (24h format, default: 23)
QUIET_HOURS_START=23

# Quiet hours end (24h format, default: 7)
QUIET_HOURS_END=7

# ─── 路徑設定（可選，預設自動偵測） ───

# 專案根目錄（預設：process.cwd()）
PROJECT_ROOT=

# Worktree 基礎目錄（預設：~/worktrees）
WORKTREE_BASE=

# 最大同時 worktree 數量（預設：4）
WORKTREE_MAX=4

# Worktree 存活時間，超過視為 orphan 自動清理（單位：小時，預設：2）
WORKTREE_TTL_HOURS=2

# Hexo Blog 目錄（預設：~/blog/myblog）
HEXO_DIR=

# ─── Cloudflare (Blog) ───

# Cloudflare API Token (for Pages deployment and D1 access)
CLOUDFLARE_API_TOKEN=

# Cloudflare Account ID
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare Zone ID (for DNS management)
CLOUDFLARE_ZONE_ID=

# Domain for the blog (e.g. arc.idv.tw → blog.arc.idv.tw)
CLOUDFLARE_DOMAIN=

# ─── 業務身份 URL ───

# Blog site URL (default: https://blog.arc.idv.tw)
BLOG_URL=https://blog.arc.idv.tw

# Report site URL (default: https://report.arc.idv.tw)
REPORT_URL=https://report.arc.idv.tw

# Cloudflare Pages project name for blog (default: blog-arc)
CF_BLOG_PROJECT=blog-arc

# Cloudflare Pages project name for report (default: report-arc)
CF_REPORT_PROJECT=report-arc
